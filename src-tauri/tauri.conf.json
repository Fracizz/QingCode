{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QingCode",
  "version": "0.1.5",
  "identifier": "com.qingcode.app",
  "build": {
    "beforeDevCommand": "pnpm dev:app",
    "devUrl": "http://127.0.0.1:38417",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "create": false,
        "title": "QingCode",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "theme": "Dark",
        "visible": false,
        "center": true,
        "backgroundColor": "#1e1e1e"
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": ["style-src"],
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "worker-src": "'self' blob:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'",
        "frame-ancestors": "'none'"
      },
      "devCsp": {
        "default-src": "'self' customprotocol: asset: http://127.0.0.1:* http://localhost:*",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' http://127.0.0.1:* http://localhost:*",
        "connect-src": "'self' ipc: http://ipc.localhost https://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:* http://localhost:* ws://localhost:*",
        "img-src": "'self' asset: http://asset.localhost blob: data: http://127.0.0.1:* http://localhost:*",
        "style-src": "'self' 'unsafe-inline' http://127.0.0.1:* http://localhost:*",
        "font-src": "'self' data: http://127.0.0.1:* http://localhost:*",
        "worker-src": "'self' blob:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
